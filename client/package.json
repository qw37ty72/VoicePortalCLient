{
  "name": "client",
  "version": "1.0.16",
  "description": "Voice Portal — голосовой чат",
  "author": "qw37ty72",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "node scripts/wait-and-launch.js",
    "build": "vite build && electron-builder --publish never",
    "release": "vite build && electron-builder --publish never",
    "release:publish": "vite build && electron-builder --publish always",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.voiceportal.app",
    "productName": "Voice Portal",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "publish": {
      "provider": "github",
      "owner": "qw37ty72",
      "repo": "VoicePortalCLient"
    },
    "win": {
      "target": ["nsis"],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qw37ty72/VoicePortalCLient.git"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "socket.io-client": "^4.7.5",
    "framer-motion": "^10.18.0",
    "lucide-react": "^0.460.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.0",
    "@timephy/rnnoise-wasm": "^1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^3.7.0",
    "vite": "^5.4.10",
    "electron": "33.2.0",
    "electron-builder": "^25.1.8",
    "concurrently": "^9.0.1",
    "wait-on": "^8.0.1",
    "rxjs": "^7.8.1"
  }
}
